{$SERVER_NAME:localhost} {

    handle /api/* {
        # CA should be configured in production for HTTPS connections.
        reverse_proxy http://backend:80
    }

    handle /live.php {
        reverse_proxy http://backend:80
    }

    handle /.well-known/mercure* {
        reverse_proxy http://backend:80
    }

    log {
        level DEBUG # Use INFO or DEBUG during development; ERROR for production
        output file /var/log/caddy/frontend.log {
            roll_size 5mb
            roll_keep 5
            roll_keep_for 7d
        }
    }

    encode zstd gzip

    # Caching for static files (by MIME type)
    @cacheable {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2
    }

    header @cacheable Cache-Control "public, max-age=31536000, immutable"

    # Security headers.
    header {
        Content-Security-Policy "default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self';"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer-when-downgrade"
    }

    # Set the document root (parameterized for flexibility)
    root * {$FRONTEND_DOC_ROOT:/usr/share/caddy}

    file_server

    # Optional SPA fallback (only for SPA projects)
    # try_files {path} /index.html

    # Error handling
    handle_errors {
        respond "Something went wrong!" 500
    }
}